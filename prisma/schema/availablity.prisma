model Availablity {
  id        String   @id @default(uuid())
  tutorId   String
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  bookingId Booking?

  @@map("availabilities")
}
