model Availablity {
  id        String   @id @default(uuid())
  tutorId   String
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@map("availablity")
}
